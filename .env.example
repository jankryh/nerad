# Preferovaný režim: API klíč zůstává na serveru/dev proxy, ne v browseru.
PID_API_KEY=your_actual_api_key_here

# Frontend volá lokální proxy (/api) místo přímého Golemio endpointu.
# To funguje jak lokálně přes Vite proxy, tak na Vercelu přes api/[...path].js.
VITE_PID_API_BASE_URL=/api

# Legacy fallback pouze pokud opravdu chcete volat Golemio přímo z browseru.
# To vystaví klíč klientovi, takže to není vhodné pro veřejný production deployment.
# VITE_PID_API_KEY=your_actual_api_key_here
